// 1. Product Database Simulation
const productDatabase = {
    "motorola-edge": {
        title: "MOTOROLA Edge 60 Fusion 5G",
        price: "₹29,999.0",
        image: "images/mobile-image.jpg",
        description: "A high-performance 5G smartphone with a sleek design and excellent camera capabilities.",
        specs: ["12GB RAM", "256GB Storage", "144Hz AMOLED Display", "50MP Primary Camera"]
    },
    "lenovo-ideapad": {
        title: "Lenovo IdeaPad Slim 3",
        price: "₹69,999.0",
        image: "images/laptop-image.jpg",
        description: "A lightweight and powerful laptop perfect for students and professionals on the go.",
        specs: ["Intel Core i5", "16GB RAM", "512GB SSD", "Windows 11 Home"]
    }
};

// 2. Initialize Page Content
function loadProductDetails() {
    const urlParams = new URLSearchParams(window.location.search);
    const productId = urlParams.get('id');

    const productContainer = document.getElementById('product-container');
    const errorContainer = document.getElementById('error-container');

    // 3. Validate and Populate
    if (productId && productDatabase[productId]) {
        const product = productDatabase[productId];
        
        // Inject Text and Images
        document.getElementById('detail-title').innerText = product.title;
        document.getElementById('detail-price').innerText = product.price;
        document.getElementById('detail-desc').innerText = product.description;
        document.getElementById('detail-image').src = product.image;

        // Inject List Items for Specs
        const specsList = document.getElementById('detail-specs');
        product.specs.forEach(spec => {
            let li = document.createElement('li');
            li.innerText = spec;
            specsList.appendChild(li);
        });

        // Toggle Visibility
        productContainer.classList.remove('hidden');
    } else {
        // Show error if ID is missing or invalid
        errorContainer.classList.remove('hidden');
    }
}

// 4. Execute on Load
window.addEventListener('DOMContentLoaded', loadProductDetails);